# Copy this file to .env and fill in real values before deploying.
#   cp .env.example .env

# --- Postgres -----------------------------------------------------------
POSTGRES_USER=ats
POSTGRES_PASSWORD=changeme-use-a-strong-random-password
POSTGRES_DB=ats

# --- App ------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SESSION_SECRET=changeme-generate-a-long-random-string
LOG_LEVEL=info

# --- Reverse proxy ----------------------------------------------------------
# Host port that nginx (the "web" service) binds to.
HTTP_PORT=80
